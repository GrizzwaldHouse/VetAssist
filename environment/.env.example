# .env.example — VetAssist Environment Configuration
# Developer: Marcus Daley
# Date: 2026-04-12
# Purpose: Template for all environment variables. Copy to .env and fill in values.
# IMPORTANT: NEVER commit .env files with real values. Only .env.example goes in git.

# ============================================
# APPLICATION
# ============================================
APP_ENV=development
APP_NAME=VetAssist
APP_VERSION=1.0.0
APP_PORT=3000
API_PORT=3001
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
VETASSIST_API_URL=http://localhost:3001/api
ALLOWED_ORIGINS=http://localhost:3000

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/vetassist
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ============================================
# AI — Anthropic Claude API
# ============================================
CLAUDE_API_KEY=sk-ant-api-PLACEHOLDER
CLAUDE_MODEL_PRIMARY=claude-sonnet-4-6
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS_CHAT=4096
CLAUDE_MAX_TOKENS_DOCUMENT=8192
CLAUDE_TEMPERATURE_CHAT=0.3
CLAUDE_TEMPERATURE_DOCUMENT=0.1

# ============================================
# VECTOR DATABASE (Chroma)
# ============================================
CHROMA_URL=http://localhost:8000
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=vetassist_knowledge

# ============================================
# HUGGING FACE
# ============================================
HF_API_TOKEN=hf_PLACEHOLDER
HF_PII_MODEL=AI-Enthusiast11/pii-entity-extractor
HF_TOXICITY_MODEL=unitary/toxic-bert

# ============================================
# SPEECH
# ============================================
WHISPER_API_KEY=sk-PLACEHOLDER
WHISPER_MODEL=whisper-1

# ============================================
# AUTHENTICATION (Auth0)
# ============================================
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=PLACEHOLDER
AUTH0_CLIENT_SECRET=PLACEHOLDER
AUTH0_AUDIENCE=https://api.vetassist.org

# ============================================
# ANALYTICS (PostHog)
# ============================================
POSTHOG_API_KEY=phc_PLACEHOLDER
POSTHOG_HOST=https://app.posthog.com
ANALYTICS_ENABLED=false

# ============================================
# FILE STORAGE
# ============================================
TEMP_STORAGE_PATH=./tmp/uploads
TEMP_STORAGE_ENCRYPTION_KEY=GENERATE_A_256_BIT_KEY
TEMP_STORAGE_DEFAULT_TTL_HOURS=24
TEMP_STORAGE_MAX_TTL_DAYS=30
MAX_UPLOAD_SIZE_MB=25

# ============================================
# PII CONFIGURATION
# ============================================
PII_DETECTION_ENABLED=true
PII_AUDIT_LOG_PATH=./logs/pii-audit.jsonl
PII_AUTO_REDACT=true
PII_BLOCK_ON_DETECTION=false

# ============================================
# COMPLIANCE
# ============================================
CRISIS_LINE_PHONE=988
CRISIS_LINE_TEXT=838255
CRISIS_LINE_URL=https://www.veteranscrisisline.net
AI_DISCLOSURE_ENABLED=true
SCORING_DEFAULT_MODE=encouraging

# ============================================
# CONTENT UPDATES
# ============================================
ECFR_API_BASE=https://www.ecfr.gov/api/versioner/v1
FEDERAL_REGISTER_API_BASE=https://www.federalregister.gov/api/v1
UPDATE_CHECK_SCHEDULE=0 6 * * *
NEWSLETTER_SCHEDULE=0 9 1 * *

# ============================================
# MODERATION
# ============================================
MODERATION_MODE=hybrid
MODERATION_LOCKDOWN=false
MODERATION_TOXICITY_THRESHOLD=0.7

# ============================================
# MONETIZATION (Config toggle — currently free)
# ============================================
PAYWALL_ENABLED=false
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER
