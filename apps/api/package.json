{
  "name": "@vetassist/api",
  "version": "0.1.0",
  "description": "VetAssist Fastify API server — chat endpoint with PII guard, crisis detection, compliance gate",
  "author": "Marcus Daley",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
