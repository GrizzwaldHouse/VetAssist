    "test": "vitest run",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/multipart": "^8.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@vetassist/ai": "*",
    "@vetassist/claims": "*",
    "@vetassist/community": "*",
    "@vetassist/moderation": "*",
    "@vetassist/benefits": "*",
    "@vetassist/upload": "*",
    "@vetassist/knowledge": "*",
    "@vetassist/compliance": "*",
    "@vetassist/crisis": "*",
    "@vetassist/events": "*",
    "@vetassist/pii": "*",
    "@vetassist/shared-config": "*",
    "@vetassist/shared-types": "*",
    "fastify": "^4.28.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
